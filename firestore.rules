rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Public website collections ──────────────────────────────
    // Public can submit contact messages and newsletter signups
    match /contacts/{document} {
      allow create: if true;
      allow read, update, delete: if true;
    }
    match /leads/{document} {
      allow create: if true;
      allow read, update, delete: if true;
    }

    // Dynamic website sections read by public, write by admin
    match /blogs/{document} {
      allow read, write: if true;
    }
    match /projects/{document} {
      allow read, write: if true;
    }
    match /testimonials/{document} {
      allow read, write: if true;
    }
    match /services/{document} {
      allow read, write: if true;
    }
    match /locations/{document} {
      allow read, write: if true;
    }

    // ── Agency CRM collections (authenticated users only) ───────
    match /users/{document} {
      allow read, write: if request.auth != null;
    }
    match /clients/{document} {
      allow read, write: if request.auth != null;
    }
    match /invoices/{document} {
      allow read, write: if request.auth != null;
    }
    match /contracts/{document} {
      allow read, write: if request.auth != null;
    }
    match /settings/{document} {
      allow read, write: if request.auth != null;
    }
  }
}
